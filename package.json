{
  "name": "kombinat-writer",
  "version": "0.1.0",
  "description": "Professional-grade book writing workflow for OpenCode — fiction, non-fiction, and mixed projects. Research ingestion, structured critique, revision cycles, citation management, and multi-format publishing. A substantial expansion of novel-writer-english.",
  "type": "module",
  "main": "bin/install.mjs",
  "bin": {
    "kombinat-writer": "bin/install.mjs"
  },
  "scripts": {
    "build": "tsc",
    "build:sidebar": "bun build src/plugins/kombinat-sidebar.tsx --outdir dist/plugins --target bun --minify",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/plugins/tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "writing",
    "novel",
    "non-fiction",
    "book",
    "opencode",
    "agent",
    "workflow",
    "publishing",
    "citation",
    "research",
    "kombinat"
  ],
  "author": "Based on the work of JeroTan and wordflowlab; substantially expanded and re-architected.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/kombinat-writer.git"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.13",
    "@opentui/solid": "^0.4.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "solid-js": "^1.9.12",
    "typescript": "^5.7.0"
  },
  "files": [
    "bin/",
    "src/tools/",
    "src/skills/",
    "src/templates/",
    "src/commands/",
    "src/lib/",
    "src/plugins/",
    "dist/plugins/",
    "SKILL.md",
    "ATTRIBUTION.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
