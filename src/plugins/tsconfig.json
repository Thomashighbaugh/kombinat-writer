{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "noEmit": true,
    "types": ["@opencode-ai/plugin"]
  },
  "include": [
    "kombinat-sidebar.tsx",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules"]
}